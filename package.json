{
  "name": "soundsok",
  "version": "1.0.0",
  "description": "SoundSok - Premium Ses Tahtası",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --enable-logging",
    "dev": "electron . --dev --enable-logging",
    "dist": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "keywords": [
    "soundboard",
    "electron",
    "audio"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.soundsok.app",
    "productName": "SoundSok",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SoundSok"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ]
  }
}
